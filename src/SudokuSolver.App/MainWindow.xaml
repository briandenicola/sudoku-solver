<Window x:Class="SudokuSolver.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SudokuSolver.App.Controls"
        xmlns:converters="clr-namespace:SudokuSolver.App.Converters"
        xmlns:vm="clr-namespace:SudokuSolver.App.ViewModels"
        Title="Sudoku Solver Tutor"
        Width="1100" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InvertBoolConverter x:Key="InvertBool" />
        <converters:NullToCollapsedConverter x:Key="NullToCollapsed" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="450" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Grid and Controls -->
        <DockPanel Grid.Column="0">
            <!-- Top: Puzzle input controls -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Sudoku Solver Tutor" FontSize="20" FontWeight="Bold" Margin="0,0,0,8" />

                <WrapPanel Margin="0,0,0,4">
                    <Button Content="📷 Load Image" Command="{Binding LoadImageCommand}"
                            Padding="12,6" Margin="0,0,8,4" Click="OnLoadImageClick" />
                    <Button Content="✏️ Manual Entry" Padding="12,6" Margin="0,0,8,4"
                            Click="OnManualEntryClick" />
                    <Button Content="⚙️ Settings" Padding="12,6" Margin="0,0,8,4"
                            Click="OnSettingsClick" />
                </WrapPanel>

                <!-- Manual entry textbox (hidden by default) -->
                <StackPanel x:Name="ManualEntryPanel" Visibility="Collapsed" Margin="0,4,0,4">
                    <TextBlock Text="Enter 81 digits (0 for empty):" FontSize="12" Margin="0,0,0,4" />
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Load" Padding="12,4" Margin="8,0,0,0"
                                Click="OnLoadManualClick" />
                        <TextBox x:Name="ManualEntryBox" FontFamily="Consolas" FontSize="12"
                                 VerticalContentAlignment="Center" />
                    </DockPanel>
                </StackPanel>

                <!-- Settings panel (hidden by default) -->
                <Border x:Name="SettingsPanel" Visibility="Collapsed" BorderBrush="LightGray"
                        BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,4,0,4">
                    <StackPanel>
                        <TextBlock Text="Ollama Settings" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="URL:" Width="60" VerticalAlignment="Center" />
                            <TextBox Text="{Binding OllamaUrl, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Model:" Width="60" VerticalAlignment="Center" />
                            <ComboBox Text="{Binding OllamaModel, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding AvailableModels}"
                                      IsEditable="True" IsTextSearchEnabled="True" />
                        </DockPanel>

                        <DockPanel Margin="0,0,0,8">
                            <Button Command="{Binding TestConnectionCommand}"
                                    Padding="10,4" DockPanel.Dock="Left" Margin="0,0,8,0"
                                    IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InvertBool}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔌 Test Connection" />
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center"
                                       TextWrapping="Wrap" FontSize="12" />
                        </DockPanel>

                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Extraction Prompt" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Content="Reset to Default" Command="{Binding ResetPromptCommand}"
                                    HorizontalAlignment="Right" Padding="8,2" FontSize="11" />
                        </DockPanel>
                        <TextBox Text="{Binding ExtractionPrompt, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="100"
                                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Bottom: Step navigation -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                <!-- Solve and Reset -->
                <WrapPanel Margin="0,0,0,8">
                    <Button Content="🧩 Solve" Command="{Binding SolveCommand}"
                            Padding="16,8" FontSize="14" FontWeight="SemiBold" Margin="0,0,8,0" />
                    <Button Content="🔄 Reset" Command="{Binding ResetCommand}"
                            Padding="12,8" Margin="0,0,8,0" />
                </WrapPanel>

                <!-- Step controls -->
                <DockPanel Margin="0,0,0,4">
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding CurrentStepIndex, StringFormat='Step {0}', FallbackValue='Step 0'}"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="⏮ Previous" Command="{Binding PreviousStepCommand}"
                                Padding="10,6" Margin="0,0,4,0" />
                        <Button Content="Next ⏭" Command="{Binding NextStepCommand}"
                                Padding="10,6" Margin="0,0,4,0" />
                        <Button Content="{Binding IsAutoPlaying, Converter={StaticResource BoolToVis}, FallbackValue='▶ Auto Play'}"
                                Command="{Binding ToggleAutoPlayCommand}"
                                Padding="10,6" Margin="0,0,4,0" />
                    </StackPanel>
                </DockPanel>

                <!-- Speed slider -->
                <DockPanel Margin="0,0,0,4">
                    <TextBlock DockPanel.Dock="Left" Text="Speed:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding AutoPlaySpeedSeconds, StringFormat='{}{0:F1}s'}"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                    <Slider Minimum="0.5" Maximum="5.0" Value="{Binding AutoPlaySpeedSeconds}"
                            TickFrequency="0.5" IsSnapToTickEnabled="True" />
                </DockPanel>

                <!-- Status bar -->
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="DarkSlateGray"
                           FontSize="12" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Center: Sudoku grid and puzzle image -->
            <TabControl Margin="0,4">
                <TabItem Header="🧩 Puzzle Grid">
                    <controls:SudokuGridControl
                        GridData="{Binding CurrentGrid}"
                        HighlightedPatternCells="{Binding HighlightedPatternCells}"
                        HighlightedAffectedCells="{Binding HighlightedAffectedCells}"
                        MinWidth="400" MinHeight="400" />
                </TabItem>
                <TabItem Header="📷 Original Image"
                         Visibility="{Binding PuzzleImage, Converter={StaticResource NullToCollapsed}}">
                    <Border BorderBrush="LightGray" BorderThickness="1">
                        <Image Source="{Binding PuzzleImage}" Stretch="Uniform"
                               MinWidth="400" MinHeight="400" />
                    </Border>
                </TabItem>
            </TabControl>
        </DockPanel>

        <!-- Right Panel: Explanation and step list -->
        <DockPanel Grid.Column="2">
            <!-- Explanation at top -->
            <Border DockPanel.Dock="Top" BorderBrush="LightGray" BorderThickness="1"
                    CornerRadius="4" Padding="12" Margin="0,0,0,8" MinHeight="120">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Step Explanation" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding CurrentExplanation, FallbackValue='Select a step to see its explanation.'}"
                                   TextWrapping="Wrap" FontSize="13" LineHeight="20" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Step list -->
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Solving Steps" FontWeight="SemiBold"
                               FontSize="14" Margin="0,0,0,8" />
                    <ListView ItemsSource="{Binding StepList}" SelectedIndex="{Binding CurrentStepIndex}"
                              BorderThickness="0" FontSize="12">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding Number, StringFormat='{}{0}. '}"
                                               FontWeight="SemiBold" Width="28" />
                                    <Border Background="{Binding Technique, Converter={x:Null}}"
                                            CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Technique}" FontSize="10"
                                                   Foreground="DarkSlateBlue" />
                                    </Border>
                                    <TextBlock Text="{Binding Summary}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </DockPanel>
            </Border>
        </DockPanel>

        <!-- Busy overlay -->
        <Border Grid.ColumnSpan="3" Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,8" />
                <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
