<Window x:Class="SudokuSolver.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:controls="clr-namespace:SudokuSolver.App.Controls"
        xmlns:converters="clr-namespace:SudokuSolver.App.Converters"
        xmlns:vm="clr-namespace:SudokuSolver.App.ViewModels"
        Title="Sudoku Solver Tutor"
        Width="1200" Height="800"
        MinWidth="960" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MaterialDesignWindow}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Background="{DynamicResource MaterialDesignPaper}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InvertBoolConverter x:Key="InvertBool" />
        <converters:NullToCollapsedConverter x:Key="NullToCollapsed" />
    </Window.Resources>

    <DockPanel>
        <!-- Top App Bar -->
        <materialDesign:ColorZone Mode="PrimaryMid" DockPanel.Dock="Top"
                                   Padding="16,8" materialDesign:ElevationAssist.Elevation="Dp2">
            <DockPanel>
                <materialDesign:PackIcon Kind="PuzzleOutline" Width="28" Height="28"
                                          VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock Text="Sudoku Solver Tutor" FontSize="20" FontWeight="Medium"
                           VerticalAlignment="Center" />
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- Main content -->
        <Grid Margin="16,12,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="480" MinWidth="420" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <DockPanel Grid.Column="0">

                <!-- Action buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <WrapPanel Margin="0,0,0,8">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Margin="0,0,8,4" Click="OnLoadImageClick"
                                materialDesign:ButtonAssist.CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ImageOutline" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Load Image" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,4" Click="OnManualEntryClick"
                                materialDesign:ButtonAssist.CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PencilOutline" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Manual Entry" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,4" Click="OnSettingsClick"
                                materialDesign:ButtonAssist.CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CogOutline" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>

                    <!-- Manual entry (collapsible) -->
                    <materialDesign:Card x:Name="ManualEntryPanel" Visibility="Collapsed"
                                          Margin="0,0,0,8" Padding="12"
                                          materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <TextBlock Text="Enter 81 digits (0 for empty)" FontSize="12"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0,0,0,8" />
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Load"
                                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                                        Margin="8,0,0,0" Click="OnLoadManualClick" />
                                <TextBox x:Name="ManualEntryBox" FontFamily="Consolas" FontSize="12"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="e.g. 530070000600195000..."
                                         VerticalContentAlignment="Center" />
                            </DockPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Settings (collapsible) -->
                    <materialDesign:Card x:Name="SettingsPanel" Visibility="Collapsed"
                                          Margin="0,0,0,8" Padding="16"
                                          materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <TextBlock Text="Ollama Configuration" FontSize="16" FontWeight="Medium" Margin="0,0,0,12" />

                            <TextBox Text="{Binding OllamaUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Server URL"
                                     Margin="0,0,0,12" />

                            <ComboBox Text="{Binding OllamaModel, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding AvailableModels}"
                                      IsEditable="True" IsTextSearchEnabled="True"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Model"
                                      Margin="0,0,0,12" />

                            <DockPanel Margin="0,0,0,12">
                                <Button Command="{Binding TestConnectionCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InvertBool}}"
                                        DockPanel.Dock="Left" Margin="0,0,12,0"
                                        materialDesign:ButtonAssist.CornerRadius="6">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="LanConnect" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock Text="Test Connection" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="{Binding ConnectionStatus}" VerticalAlignment="Center"
                                           TextWrapping="Wrap" FontSize="12" />
                            </DockPanel>

                            <Separator Margin="0,0,0,12" />

                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="Extraction Prompt" FontWeight="Medium" VerticalAlignment="Center" />
                                <Button Content="Reset" Command="{Binding ResetPromptCommand}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        HorizontalAlignment="Right" FontSize="11" />
                            </DockPanel>
                            <TextBox Text="{Binding ExtractionPrompt, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     AcceptsReturn="True" TextWrapping="Wrap" Height="100"
                                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" />
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>

                <!-- Bottom: Step navigation -->
                <materialDesign:Card DockPanel.Dock="Bottom" Padding="12" Margin="0,8,0,0"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <StackPanel>
                        <!-- Solve / Reset -->
                        <WrapPanel Margin="0,0,0,8">
                            <Button Command="{Binding SolveCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    FontSize="14" Margin="0,0,8,0"
                                    materialDesign:ButtonAssist.CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PlayCircleOutline" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Solve" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ResetCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,0,8,0"
                                    materialDesign:ButtonAssist.CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Reset" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <!-- Step navigation -->
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding CurrentStepIndex, StringFormat='Step {0}'}"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding PreviousStepCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Previous Step">
                                    <materialDesign:PackIcon Kind="SkipPrevious" />
                                </Button>
                                <Button Command="{Binding NextStepCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Next Step">
                                    <materialDesign:PackIcon Kind="SkipNext" />
                                </Button>
                                <Button Command="{Binding ToggleAutoPlayCommand}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Auto Play">
                                    <materialDesign:PackIcon Kind="PlayPause" />
                                </Button>
                            </StackPanel>
                        </DockPanel>

                        <!-- Speed slider -->
                        <DockPanel Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="SpeedometerSlow" DockPanel.Dock="Left"
                                                      VerticalAlignment="Center" Margin="0,0,8,0"
                                                      Foreground="{DynamicResource MaterialDesignBodyLight}" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding AutoPlaySpeedSeconds, StringFormat='{}{0:F1}s'}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                            <Slider Minimum="0.5" Maximum="5.0" Value="{Binding AutoPlaySpeedSeconds}"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    Style="{StaticResource MaterialDesignDiscreteSlider}" />
                        </DockPanel>

                        <!-- Status -->
                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </materialDesign:Card>

                <!-- Center: Puzzle grid / image tabs -->
                <TabControl Margin="0,4"
                            Style="{StaticResource MaterialDesignNavigationRailTabControl}">
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Grid" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Grid" HorizontalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </TabItem.Header>
                        <controls:SudokuGridControl
                            GridData="{Binding CurrentGrid}"
                            HighlightedPatternCells="{Binding HighlightedPatternCells}"
                            HighlightedAffectedCells="{Binding HighlightedAffectedCells}"
                            Margin="8" MinWidth="400" MinHeight="400" />
                    </TabItem>
                    <TabItem Visibility="{Binding PuzzleImage, Converter={StaticResource NullToCollapsed}}">
                        <TabItem.Header>
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Image" Width="24" Height="24" HorizontalAlignment="Center" />
                                <TextBlock Text="Photo" HorizontalAlignment="Center" FontSize="11" />
                            </StackPanel>
                        </TabItem.Header>
                        <Border Margin="8">
                            <Image Source="{Binding PuzzleImage}" Stretch="Uniform"
                                   MinWidth="400" MinHeight="400" />
                        </Border>
                    </TabItem>
                </TabControl>
            </DockPanel>

            <!-- Right Panel -->
            <DockPanel Grid.Column="2">
                <!-- Explanation card -->
                <materialDesign:Card DockPanel.Dock="Top" Padding="16" Margin="0,0,0,12"
                                      MinHeight="130"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="LightbulbOnOutline" Margin="0,0,8,0"
                                                          VerticalAlignment="Center"
                                                          Foreground="{DynamicResource SecondaryHueMidBrush}" />
                                <TextBlock Text="Step Explanation" FontSize="16" FontWeight="Medium" />
                            </StackPanel>
                            <TextBlock Text="{Binding CurrentExplanation, FallbackValue='Select a step to see its explanation.'}"
                                       TextWrapping="Wrap" FontSize="13" LineHeight="22"
                                       Foreground="{DynamicResource MaterialDesignBody}" />
                        </StackPanel>
                    </ScrollViewer>
                </materialDesign:Card>

                <!-- Step list card -->
                <materialDesign:Card Padding="12" materialDesign:ElevationAssist.Elevation="Dp1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,0,0,8">
                            <materialDesign:PackIcon Kind="FormatListNumbered" Margin="0,0,8,0"
                                                      VerticalAlignment="Center"
                                                      Foreground="{DynamicResource PrimaryHueMidBrush}" />
                            <TextBlock Text="Solving Steps" FontSize="16" FontWeight="Medium" />
                        </StackPanel>
                        <ListView ItemsSource="{Binding StepList}" SelectedIndex="{Binding CurrentStepIndex}"
                                  BorderThickness="0" FontSize="12">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="2,4">
                                        <TextBlock Text="{Binding Number, StringFormat='{}{0}.'}"
                                                   FontWeight="SemiBold" Width="28"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}" />
                                        <Border Background="{DynamicResource MaterialDesignToolBarBackground}"
                                                CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Technique}" FontSize="10"
                                                       Foreground="{DynamicResource PrimaryHueMidBrush}" FontWeight="Medium" />
                                        </Border>
                                        <TextBlock Text="{Binding Summary}" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>
                </materialDesign:Card>
            </DockPanel>

            <!-- Busy overlay -->
            <Border Grid.ColumnSpan="3" Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True" Width="48" Height="48" Margin="0,0,0,16" />
                    <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" FontSize="14" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
