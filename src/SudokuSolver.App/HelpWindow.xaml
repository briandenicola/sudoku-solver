<Window x:Class="SudokuSolver.App.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Technique Guide — Sudoku Solver Tutor"
        Width="800" Height="650"
        MinWidth="600" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        Icon="Resources/app.ico"
        Style="{StaticResource MaterialDesignWindow}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="13"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Background="{DynamicResource MaterialDesignPaper}">

    <DockPanel>
        <!-- Header -->
        <materialDesign:ColorZone Mode="PrimaryMid" DockPanel.Dock="Top"
                                   Padding="16,10" materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="SchoolOutline" Width="24" Height="24"
                                          VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock Text="Solving Techniques Guide" FontSize="18" FontWeight="Medium"
                           VerticalAlignment="Center" />
            </StackPanel>
        </materialDesign:ColorZone>

        <!-- Two-column layout: technique list on left, detail on right -->
        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Technique list -->
            <materialDesign:Card Grid.Column="0" Padding="0"
                                  materialDesign:ElevationAssist.Elevation="Dp1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Techniques" FontWeight="Medium" FontSize="14"
                               Margin="12,12,12,8" />
                    <ListBox x:Name="TechniqueList" SelectionChanged="OnTechniqueSelected"
                             BorderThickness="0" Padding="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="4,6">
                                    <Border DockPanel.Dock="Right"
                                            Background="{DynamicResource MaterialDesignToolBarBackground}"
                                            CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Difficulty}" FontSize="10"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                   FontWeight="Medium" />
                                    </Border>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </materialDesign:Card>

            <!-- Detail panel -->
            <materialDesign:Card Grid.Column="2" Padding="20"
                                  materialDesign:ElevationAssist.Elevation="Dp1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel">
                        <TextBlock x:Name="DetailTitle" FontSize="20" FontWeight="Medium"
                                   Margin="0,0,0,4" />
                        <Border x:Name="DifficultyBadge"
                                Background="{DynamicResource SecondaryHueLightBrush}"
                                CornerRadius="4" Padding="8,3" HorizontalAlignment="Left"
                                Margin="0,0,0,16">
                            <TextBlock x:Name="DetailDifficulty" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryHueMidBrush}" />
                        </Border>
                        <TextBlock x:Name="DetailShort" FontSize="14" FontWeight="Medium"
                                   TextWrapping="Wrap" Margin="0,0,0,16"
                                   Foreground="{DynamicResource PrimaryHueMidBrush}" />
                        <TextBlock x:Name="DetailExplanation" TextWrapping="Wrap"
                                   FontSize="13" LineHeight="22"
                                   Foreground="{DynamicResource MaterialDesignBody}" />
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>
    </DockPanel>
</Window>
